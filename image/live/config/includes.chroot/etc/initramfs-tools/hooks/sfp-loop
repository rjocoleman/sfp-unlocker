#!/bin/sh
# Ensure losetup and the loop module are in the initramfs so the
# init-premount/sfp-loop script can attach the embedded ISO.
PREREQ=""
prereqs() { echo "$PREREQ"; }
case "${1:-}" in
prereqs)
	prereqs
	exit 0
	;;
esac

. /usr/share/initramfs-tools/hook-functions

copy_exec /sbin/losetup /sbin
force_load loop
