#!ipxe
# iPXE downloads the self-contained live ISO into RAM and boots it directly.
# The ISO carries the kernel, modules, ethtool and the tool, so nothing else is
# fetched at boot. Override ${base} to host the ISO elsewhere.

set base https://github.com/rjocoleman/sfp-unlocker/releases/latest/download
set version dev

echo
echo sfp-unlocker ${version} - RAM-booting ${base}/sfp-unlocker.iso
echo

sanboot ${base}/sfp-unlocker.iso
